{
  "name": "novaproof",
  "version": "0.1.0",
  "description": "The verifiable execution log protocol for AI agents on Base",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:sepolia": "hardhat run deploy/deploy.ts --network base-sepolia",
    "deploy:mainnet": "hardhat run deploy/deploy.ts --network base-mainnet",
    "build:sdk": "cd sdk && npm run build",
    "build:api": "cd api && npm run build",
    "build": "npm run compile && npm run build:sdk && npm run build:api",
    "dev:api": "cd api && npm run dev",
    "clean": "hardhat clean && cd sdk && npm run clean && cd ../api && npm run clean"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.1.0",
    "dotenv": "^16.4.0",
    "hardhat": "^2.22.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "novaproof",
    "ai-agents",
    "base",
    "blockchain",
    "execution-log",
    "reputation",
    "erc-8004",
    "merkle-tree"
  ],
  "author": "Nova × Cana",
  "license": "MIT",
  "dependencies": {
    "viem": "^2.46.3"
  }
}
