# ─── AgentChain Configuration ─────────────────────────────────────────

# Deployer / Agent Owner private key (with 0x prefix)
PRIVATE_KEY=0x_your_private_key_here

# Base RPC URLs
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Basescan API key (for contract verification)
BASESCAN_API_KEY=your_basescan_api_key

# ─── Contract (populated after deployment) ────────────────────────────

CONTRACT_ADDRESS=0x_deployed_contract_address

# ─── API Server ───────────────────────────────────────────────────────

PORT=3100
CHAIN_ID=84532

# Relayer private key (for the API to submit commits on behalf of agents)
RELAYER_PRIVATE_KEY=0x_relayer_private_key

# API key to protect the relayer endpoint (optional)
API_KEY=your_api_key_for_relayer

# ─── SDK Configuration ───────────────────────────────────────────────

AGENTCHAIN_AGENT_ID=0
AGENTCHAIN_CONTRACT=0x_deployed_contract_address
AGENTCHAIN_RPC_URL=https://sepolia.base.org
AGENTCHAIN_MODE=direct
AGENTCHAIN_PRIVATE_KEY=0x_your_agent_private_key
AGENTCHAIN_RELAYER_URL=http://localhost:3100
AGENTCHAIN_RELAYER_API_KEY=your_api_key
AGENTCHAIN_CHAIN_ID=84532
AGENTCHAIN_AUTO_COMMIT=0
